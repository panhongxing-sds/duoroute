# Secrets / local overrides
configs/embedding_api.local.yaml
**/*.local.yaml

# Python
__pycache__/
*.egg-info/
.venv/
.pytest_cache/

# Large data (shipped via GitHub Release — see docs/DATA_DOWNLOAD.md)
data/seed42_flagship/**
data/seed42_small/**
data/processed/
data/seed42_exp/
data/seed42_synth/
data/**/*.log

# Release tarball (upload manually to GitHub Release)
data_pack/*.tar.zst
data_pack/*.tar.gz

# Embeddings & weights (in release tarball)
*.pth
*.npz
**/meta.json
**/meta.json.gz

# Regeneratable outputs
outputs/**

# Temp
.tmp/
logs/
